# =============================================================================
# DNA Trait Analyzer — Environment Variables
# =============================================================================
# Copy this file to .env.local:  cp .env.example .env.local
# Or run ./scripts/setup.sh to do it automatically.
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic (REQUIRED)
# -----------------------------------------------------------------------------
# Your Anthropic API key for Claude. Get one at:
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Supabase (REQUIRED for auth and report persistence)
# -----------------------------------------------------------------------------
# For local development with Supabase CLI, these are auto-filled by setup.sh.
# For a hosted project, get these from: https://supabase.com/dashboard/project/_/settings/api
#
# Local defaults (if using `supabase start`):
#   URL:      http://127.0.0.1:54321
#   Anon key: (shown by `supabase status`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — used by webhook handler to bypass RLS.
# Only needed server-side; never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Stripe (OPTIONAL — needed for payments)
# -----------------------------------------------------------------------------
# Get test keys from: https://dashboard.stripe.com/test/apikeys
# The app works without Stripe keys (pricing buttons will be disabled).
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — get this by running:
#   stripe listen --forward-to localhost:3000/api/stripe/webhook
# The CLI will print the signing secret on startup.
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create products and prices in your Stripe Dashboard:
# https://dashboard.stripe.com/test/products
#   - Per Trait: one-time payment, $0.99
#   - Starter:   one-time payment, $9.99
#   - Monthly:   recurring monthly, $14.99/mo
#   - Annual:    recurring yearly, $99/yr
STRIPE_PRICE_PER_TRAIT=price_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
